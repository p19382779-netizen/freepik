import React, { useState, useEffect, useRef } from 'react';
import { motion, useScroll, useSpring, AnimatePresence } from 'framer-motion';
import { 
  ShieldAlert, Moon, Sun, Menu, X, CheckCircle2, 
  Circle, Download, BookOpen, AlertTriangle, Info, CheckSquare, Sparkles, Image as ImageIcon, ZoomIn
} from 'lucide-react';

// --- ДАННЫЕ И КОНТЕНТ ---

const SECTIONS = [
  { id: 'intro', title: '1. Введение' },
  { id: 'basics', title: '2. Базовые принципы' },
  { id: 'licenses', title: '3. Типы лицензий' },
  { id: 'ai-content', title: '4. ИИ-контент' },
  { id: 'workflow', title: '5. Порядок работы' },
  { id: 'errors', title: '6. Ошибки и риски' },
  { id: 'recommendations', title: '7. Рекомендации' },
  { id: 'contract', title: '8. Договор с клиентом' },
  { id: 'checklist', title: '9. Чек-лист' },
];

const CHECKLIST_ITEMS = [
  "Вы понимаете сценарий использования ассета",
  "Проверен тип лицензии и ограничения",
  "Лицензия скачана и сохранена",
  "Ассет используется только как часть итогового дизайна",
  "Клиент проинформирован о лицензионных ограничениях",
  "ИИ‑контент не применяется для логотипов и брендинга",
  "Подписка используется только вами",
  "Распределение ответственности зафиксировано в договоре"
];

const AUTHORS = [
  {
    name: 'Алёна Кондратенко',
    channel: '@alenkadesigner',
    link: 'https://t.me/alenkadesigner',
    image: 'https://i.postimg.cc/QMRG5thd/photo-2025-10-16-14-29-17.jpg'
  },
  {
    name: 'Паша Скворцов',
    channel: '@skvortsov_slides',
    link: 'https://t.me/skvortsov_slides',
    image: 'https://i.postimg.cc/kXw0swqs/photo-2026-02-07-00-17-29.jpg'
  }
];

// --- УТИЛИТЫ ---

const getFallbackAvatar = (name) => {
  const initials = name
    .split(' ')
    .map(n => n[0])
    .join('')
    .substring(0, 2)
    .toUpperCase();
    
  const svg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 128 128">
    <rect width="128" height="128" fill="#2563EB"/>
    <text x="50%" y="50%" dominant-baseline="central" text-anchor="middle" fill="#ffffff" font-family="system-ui, sans-serif" font-size="50" font-weight="600">${initials}</text>
  </svg>`;
  
  return `data:image/svg+xml;charset=utf-8,${encodeURIComponent(svg)}`;
};

// --- КОМПОНЕНТЫ ---

// 1. Индикатор прогресса чтения
const ProgressBar = () => {
  const { scrollYProgress } = useScroll();
  const scaleX = useSpring(scrollYProgress, {
    stiffness: 100,
    damping: 30,
    restDelta: 0.001
  });

  return (
    <motion.div
      className="fixed top-0 left-0 right-0 h-1.5 bg-blue-600 dark:bg-blue-500 origin-left z-50"
      style={{ scaleX }}
    />
  );
};

// 2. Юридический блок (Legal Warning)
const LegalWarning = ({ title = "Важно", children, icon: Icon = ShieldAlert, type = "warning" }) => {
  const colors = {
    warning: "border-orange-200 bg-orange-50 text-orange-900 dark:border-orange-900/50 dark:bg-orange-950/20 dark:text-orange-100",
    info: "border-blue-200 bg-blue-50 text-blue-900 dark:border-blue-900/50 dark:bg-blue-950/20 dark:text-blue-100",
    success: "border-green-200 bg-green-50 text-green-900 dark:border-green-900/50 dark:bg-green-950/20 dark:text-green-100"
  };

  const iconColors = {
    warning: "text-orange-600 dark:text-orange-400 bg-orange-100 dark:bg-orange-900/50",
    info: "text-blue-600 dark:text-blue-400 bg-blue-100 dark:bg-blue-900/50",
    success: "text-green-600 dark:text-green-400 bg-green-100 dark:bg-green-900/50"
  };

  return (
    <motion.div
      initial={{ opacity: 0, y: 20 }}
      whileInView={{ opacity: 1, y: 0 }}
      viewport={{ once: true, margin: "-50px" }}
      transition={{ duration: 0.5 }}
      className={`my-8 p-6 rounded-2xl border relative overflow-hidden break-inside-avoid ${colors[type]}`}
    >
      <div className="absolute -right-4 -top-4 opacity-5 dark:opacity-10 pointer-events-none">
        <Icon size={120} />
      </div>
      <div className="flex items-start gap-4 relative z-10">
        <div className={`p-2 rounded-lg shrink-0 mt-1 ${iconColors[type]}`}>
          <Icon size={24} />
        </div>
        <div>
          <h4 className="text-lg font-bold mb-2">{title}</h4>
          <div className="opacity-90 leading-relaxed space-y-2 text-sm sm:text-base">
            {children}
          </div>
        </div>
      </div>
    </motion.div>
  );
};

// 3. Интерактивный Чек-лист
const InteractiveChecklist = () => {
  const [checkedItems, setCheckedItems] = useState(new Set());

  const toggleItem = (index) => {
    const newChecked = new Set(checkedItems);
    if (newChecked.has(index)) {
      newChecked.delete(index);
    } else {
      newChecked.add(index);
    }
    setCheckedItems(newChecked);
  };

  const progress = Math.round((checkedItems.size / CHECKLIST_ITEMS.length) * 100);

  return (
    <div className="my-8 p-6 sm:p-8 bg-white dark:bg-slate-800 rounded-3xl shadow-sm border border-slate-200 dark:border-slate-700 break-inside-avoid">
      <div className="flex items-center justify-between mb-6">
        <h3 className="text-xl font-bold flex items-center gap-2">
          <CheckSquare className="text-blue-600 dark:text-blue-400" />
          Финальная проверка
        </h3>
        <span className="text-sm font-medium px-3 py-1 bg-blue-100 dark:bg-blue-900/50 text-blue-700 dark:text-blue-300 rounded-full">
          {progress}%
        </span>
      </div>
      
      <div className="w-full bg-slate-100 dark:bg-slate-700 h-2 rounded-full mb-8 overflow-hidden">
        <motion.div 
          className="bg-blue-600 dark:bg-blue-500 h-full"
          initial={{ width: 0 }}
          animate={{ width: `${progress}%` }}
          transition={{ duration: 0.3 }}
        />
      </div>

      <div className="space-y-3">
        {CHECKLIST_ITEMS.map((item, index) => {
          const isChecked = checkedItems.has(index);
          return (
            <motion.button
              key={index}
              whileHover={{ scale: 1.01 }}
              whileTap={{ scale: 0.99 }}
              onClick={() => toggleItem(index)}
              className={`w-full text-left flex items-start gap-4 p-4 rounded-xl border transition-colors ${
                isChecked 
                  ? 'bg-blue-50/50 border-blue-200 dark:bg-blue-900/20 dark:border-blue-800' 
                  : 'bg-slate-50 border-slate-200 dark:bg-slate-800/50 dark:border-slate-700 hover:border-blue-300 dark:hover:border-blue-600'
              }`}
            >
              <div className="mt-0.5 shrink-0">
                {isChecked ? (
                  <motion.div
                    initial={{ scale: 0 }}
                    animate={{ scale: 1 }}
                    transition={{ type: "spring", stiffness: 300, damping: 20 }}
                  >
                    <CheckCircle2 className="text-blue-600 dark:text-blue-400" size={24} />
                  </motion.div>
                ) : (
                  <Circle className="text-slate-400 dark:text-slate-500" size={24} />
                )}
              </div>
              <span className={`text-sm sm:text-base transition-all duration-300 ${
                isChecked ? 'text-slate-500 dark:text-slate-400 line-through' : 'text-slate-700 dark:text-slate-200'
              }`}>
                {item}
              </span>
            </motion.button>
          );
        })}
      </div>
    </div>
  );
};

// 4. Компонент Секции (Обертка для контента)
const Section = ({ id, title, children }) => (
  <motion.section
    id={id}
    initial={{ opacity: 0, y: 20 }}
    whileInView={{ opacity: 1, y: 0 }}
    viewport={{ once: true, margin: "-100px" }}
    transition={{ duration: 0.6 }}
    className="scroll-mt-24 mb-16"
  >
    <h2 className="text-2xl sm:text-3xl font-bold mb-6 text-slate-900 dark:text-white pb-2 border-b border-slate-200 dark:border-slate-800">
      {title}
    </h2>
    <div className="space-y-4 text-slate-700 dark:text-slate-300 text-lg leading-relaxed">
      {children}
    </div>
  </motion.section>
);

// --- ГЛАВНЫЙ КОМПОНЕНТ APP ---

export default function App() {
  const [isDark, setIsDark] = useState(false);
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  const [activeSection, setActiveSection] = useState(SECTIONS[0].id);
  const [isDownloading, setIsDownloading] = useState(false);
  const [zoomedImg, setZoomedImg] = useState(null); // Состояние для увеличенного фото

  useEffect(() => {
    if (isDark) {
      document.documentElement.classList.add('dark');
    } else {
      document.documentElement.classList.remove('dark');
    }
  }, [isDark]);

  // Блокируем скролл фона, если открыто фото
  useEffect(() => {
    if (zoomedImg) {
      document.body.style.overflow = 'hidden';
    } else {
      document.body.style.overflow = 'unset';
    }
    return () => { document.body.style.overflow = 'unset'; };
  }, [zoomedImg]);

  useEffect(() => {
    const handleScroll = () => {
      const sectionElements = SECTIONS.map(s => document.getElementById(s.id));
      const currentScrollPos = window.scrollY + 150;

      for (let i = sectionElements.length - 1; i >= 0; i--) {
        const section = sectionElements[i];
        if (section && section.offsetTop <= currentScrollPos) {
          setActiveSection(section.id);
          break;
        }
      }
    };

    window.addEventListener('scroll', handleScroll);
    return () => window.removeEventListener('scroll', handleScroll);
  }, []);

  const scrollTo = (id) => {
    const element = document.getElementById(id);
    if (element) {
      element.scrollIntoView({ behavior: 'smooth' });
    }
    setIsMobileMenuOpen(false);
  };

  const handleDownloadPDF = () => {
    setIsDownloading(true);
    setZoomedImg(null); // Закрываем увеличенное фото, если оно открыто перед скачиванием
    
    if (window.html2pdf) {
      generatePDF();
      return;
    }

    const script = document.createElement('script');
    script.src = 'https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js';
    script.onload = generatePDF;
    document.body.appendChild(script);
  };

  const generatePDF = () => {
    const htmlElement = document.documentElement;
    const wasDark = htmlElement.classList.contains('dark');
    if (wasDark) htmlElement.classList.remove('dark');

    const element = document.getElementById('content-to-pdf');
    const actionButtons = document.getElementById('pdf-action-buttons');

    const originalCss = element.style.cssText;
    const originalButtonsDisplay = actionButtons ? actionButtons.style.display : '';

    if (actionButtons) actionButtons.style.display = 'none';

    const style = document.createElement('style');
    style.id = 'pdf-fix-animations';
    style.innerHTML = `
      #content-to-pdf * {
        opacity: 1 !important;
        transform: none !important;
        animation: none !important;
        transition: none !important;
      }
    `;
    document.head.appendChild(style);

    setTimeout(() => {
      element.style.cssText = 'padding: 40px !important; background: white !important; box-sizing: border-box !important;';

      const pdfWidth = element.offsetWidth;
      const pdfHeight = element.scrollHeight + 5;

      const opt = {
        margin: 0,
        filename: 'Гайд_по_лицензиям_Freepik.pdf',
        image: { type: 'jpeg', quality: 1 },
        html2canvas: { 
          scale: 2, 
          useCORS: true, 
          windowWidth: document.documentElement.clientWidth,
          scrollY: 0 
        },
        jsPDF: { 
          unit: 'px', 
          format: [pdfWidth, pdfHeight], 
          orientation: 'portrait',
          hotfixes: ["px_scaling"]
        }
      };

      window.html2pdf().set(opt).from(element).save().then(() => {
        setIsDownloading(false);
        element.style.cssText = originalCss;
        if (actionButtons) actionButtons.style.display = originalButtonsDisplay;
        if (wasDark) htmlElement.classList.add('dark');
        
        const injectedStyle = document.getElementById('pdf-fix-animations');
        if (injectedStyle) injectedStyle.remove();
      });
    }, 100);
  };

  return (
    <div className={`min-h-screen bg-slate-50 dark:bg-slate-950 font-sans transition-colors duration-300 selection:bg-blue-200 selection:text-blue-900 dark:selection:bg-blue-900 dark:selection:text-blue-100 relative`}>
      <ProgressBar />

      {/* Шапка (Header) */}
      <header className="fixed top-0 w-full z-40 bg-white/80 dark:bg-slate-950/80 backdrop-blur-md border-b border-slate-200 dark:border-slate-800">
        <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
          <div className="flex items-center gap-3 text-blue-600 dark:text-blue-400 font-bold text-lg cursor-pointer" onClick={() => window.scrollTo({top:0, behavior: 'smooth'})}>
            <BookOpen size={24} />
            <span className="hidden sm:inline">Гайд по лицензиям Freepik</span>
            <span className="sm:hidden">Freepik Guide</span>
          </div>
          
          <div className="flex items-center gap-4">
            <button
              onClick={() => setIsDark(!isDark)}
              className="p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 transition-colors text-slate-600 dark:text-slate-300"
              aria-label="Toggle Theme"
            >
              {isDark ? <Sun size={20} /> : <Moon size={20} />}
            </button>
            <button
              className="md:hidden p-2 rounded-full hover:bg-slate-100 dark:hover:bg-slate-800 text-slate-600 dark:text-slate-300"
              onClick={() => setIsMobileMenuOpen(!isMobileMenuOpen)}
            >
              {isMobileMenuOpen ? <X size={24} /> : <Menu size={24} />}
            </button>
          </div>
        </div>
      </header>

      {/* Мобильное меню */}
      {isMobileMenuOpen && (
        <motion.div 
          initial={{ opacity: 0, y: -20 }}
          animate={{ opacity: 1, y: 0 }}
          exit={{ opacity: 0, y: -20 }}
          className="md:hidden fixed top-16 left-0 right-0 bottom-0 bg-white dark:bg-slate-950 z-30 p-4 overflow-y-auto"
        >
          <nav className="flex flex-col gap-2">
            {SECTIONS.map((section) => (
              <button
                key={section.id}
                onClick={() => scrollTo(section.id)}
                className={`text-left px-4 py-3 rounded-xl transition-colors ${
                  activeSection === section.id 
                    ? 'bg-blue-50 text-blue-600 dark:bg-blue-900/20 dark:text-blue-400 font-medium' 
                    : 'text-slate-600 dark:text-slate-400 hover:bg-slate-50 dark:hover:bg-slate-900'
                }`}
              >
                {section.title}
              </button>
            ))}
          </nav>
        </motion.div>
      )}

      {/* Основной контент */}
      <div className="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-24 pb-20 flex gap-12">
        
        {/* Боковая навигация (Desktop) */}
        <aside className="hidden md:block w-64 shrink-0">
          <div className="sticky top-28">
            <h3 className="text-xs font-bold uppercase tracking-wider text-slate-400 dark:text-slate-500 mb-4 px-3">
              Содержание
            </h3>
            <nav className="flex flex-col gap-1 relative border-l-2 border-slate-100 dark:border-slate-800 ml-3">
              {SECTIONS.map((section) => (
                <button
                  key={section.id}
                  onClick={() => scrollTo(section.id)}
                  className={`text-left pl-4 py-2 text-sm transition-all relative ${
                    activeSection === section.id
                      ? 'text-blue-600 dark:text-blue-400 font-medium'
                      : 'text-slate-500 dark:text-slate-400 hover:text-slate-900 dark:hover:text-slate-200'
                  }`}
                >
                  {/* Индикатор активного пункта */}
                  {activeSection === section.id && (
                    <motion.div 
                      layoutId="activeIndicator"
                      className="absolute left-[-2px] top-0 bottom-0 w-0.5 bg-blue-600 dark:bg-blue-400"
                    />
                  )}
                  {section.title}
                </button>
              ))}
            </nav>
          </div>
        </aside>

        {/* Статья */}
        <main id="content-to-pdf" className="flex-1 max-w-3xl protect-content">
          
          {/* Hero Секция */}
          <motion.div 
            initial={{ opacity: 0, y: 30 }}
            animate={{ opacity: 1, y: 0 }}
            transition={{ duration: 0.7 }}
            className="mb-16 pt-8 md:pt-16"
          >
            <div className="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-blue-100 text-blue-700 dark:bg-blue-900/40 dark:text-blue-300 text-sm font-medium mb-6">
              Методическое руководство интенсива
            </div>
            <h1 className="text-4xl sm:text-5xl font-extrabold text-slate-900 dark:text-white tracking-tight mb-6 leading-tight">
              Авторские права и лицензии при работе с Freepik
            </h1>
            
            <div className="flex flex-col sm:flex-row gap-4 mb-8 break-inside-avoid">
              {AUTHORS.map((author, idx) => (
                <a 
                  key={idx}
                  href={author.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  className="flex flex-1 items-center gap-4 p-4 rounded-2xl bg-white dark:bg-slate-800/80 border border-slate-200 dark:border-slate-700 hover:border-blue-400 dark:hover:border-blue-500 shadow-sm hover:shadow-md transition-all group"
                >
                  <img 
                    src={author.image} 
                    alt={author.name} 
                    onError={(e) => {
                      e.target.onerror = null;
                      e.target.src = getFallbackAvatar(author.name);
                    }}
                    className="w-14 h-14 sm:w-16 sm:h-16 rounded-full object-cover border-2 border-slate-100 dark:border-slate-700 group-hover:scale-105 transition-transform bg-slate-100 dark:bg-slate-800"
                  />
                  <div>
                    <h4 className="font-bold text-slate-900 dark:text-white leading-tight mb-0.5">{author.name}</h4>
                    <span className="text-blue-600 dark:text-blue-400 text-sm font-medium">{author.channel}</span>
                  </div>
                </a>
              ))}
            </div>

            <div id="pdf-action-buttons" className="flex flex-wrap gap-4">
              <button 
                onClick={() => scrollTo('intro')}
                className="px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white rounded-xl font-medium transition-colors shadow-sm shadow-blue-600/20"
              >
                Начать чтение
              </button>
              
              <button 
                onClick={handleDownloadPDF}
                disabled={isDownloading}
                className={`px-6 py-3 rounded-xl font-medium transition-colors border shadow-sm flex items-center gap-2 ${
                  isDownloading 
                    ? 'bg-slate-100 text-slate-400 border-slate-200 dark:bg-slate-800 dark:text-slate-500 dark:border-slate-700 cursor-not-allowed'
                    : 'bg-white hover:bg-slate-50 text-slate-700 dark:bg-slate-800 dark:text-slate-200 dark:hover:bg-slate-700 border-slate-200 dark:border-slate-700'
                }`}
              >
                {isDownloading ? (
                  <>
                    <div className="w-4 h-4 border-2 border-current border-t-transparent rounded-full animate-spin" />
                    Формируем PDF...
                  </>
                ) : (
                  <>
                    <Download size={18} />
                    Скачать PDF
                  </>
                )}
              </button>
            </div>
          </motion.div>

          <Section id="intro" title="1. Введение: зачем дизайнеру понимать авторское право">
            <p>Работа с графическими стоковыми платформами стала стандартной частью профессиональной деятельности дизайнеров, иллюстраторов, маркетологов и специалистов по визуальному контенту. Использование готовых изображений, иконок, шаблонов и иллюстраций позволяет значительно ускорять производство проектов, однако одновременно накладывает юридические ограничения.</p>
            <p>Каждый графический элемент, размещённый на стоковой платформе, является объектом интеллектуальной собственности. Его использование допускается только на основании <strong>лицензии</strong> — специального разрешения правообладателя.</p>
            
            <LegalWarning title="Отсутствие понимания условий лицензирования приводит к нарушениям:" icon={AlertTriangle} type="warning">
              <ul className="list-disc pl-5 mt-2 space-y-1">
                <li>использованию изображений без законных оснований;</li>
                <li>передаче заказчику материалов, которыми он не вправе распоряжаться;</li>
                <li>применению ассетов в рекламе или коммерческих проектах сверх разрешённого объёма;</li>
                <li>конфликтам между дизайнером и заказчиком при публикации проекта.</li>
              </ul>
            </LegalWarning>

            <p className="mt-4">Для начинающего специалиста ключевая задача — научиться воспринимать стоковый контент не как «скачанные картинки», а как лицензируемые объекты с установленным режимом использования.</p>
            <p className="text-sm italic text-slate-500 dark:text-slate-400 mt-2">Настоящее руководство объясняет правила работы со стоковыми материалами на примере сервиса Freepik с учётом практики работы дизайнеров и базовых принципов российского законодательства об авторском праве.</p>
          </Section>

          <Section id="basics" title="2. Базовые принципы">
            <p>Для работы со стоками достаточно усвоить несколько ключевых принципов применительно к стоковому контенту.</p>
            
            <div className="grid sm:grid-cols-2 gap-4 mt-6">
              <div className="bg-white dark:bg-slate-800/50 p-5 rounded-2xl border border-slate-200 dark:border-slate-700 break-inside-avoid">
                <h4 className="font-bold text-slate-900 dark:text-white mb-2">2.1. Что защищается авторским правом</h4>
                <p className="text-sm">В рамках законодательства РФ объектами признаются: иллюстрации, фотографии, шрифты, графические композиции, шаблоны дизайна, 3D‑модели, элементы интерфейсов. Сам факт размещения материала в интернете не означает его свободное использование.</p>
              </div>
              <div className="bg-white dark:bg-slate-800/50 p-5 rounded-2xl border border-slate-200 dark:border-slate-700 break-inside-avoid">
                <h4 className="font-bold text-slate-900 dark:text-white mb-2">2.2. Лицензия как основной способ</h4>
                <p className="text-sm">При скачивании ассета пользователь не приобретает сам объект интеллектуальной собственности. Он получает право использовать его в пределах определённых условий. Дизайнер передаёт заказчику не исходный стоковый объект, а результат своей работы.</p>
              </div>
              <div className="bg-white dark:bg-slate-800/50 p-5 rounded-2xl border border-slate-200 dark:border-slate-700 break-inside-avoid">
                <h4 className="font-bold text-slate-900 dark:text-white mb-2">2.3. Разграничение прав</h4>
                <p className="text-sm">Дизайнер отвечает за законность использования ассета на момент работы. Заказчик отвечает за дальнейшее использование результата проекта. Если заказчик планирует массовую рекламу или мерч, он обязан проверить необходимость дополнительных лицензий.</p>
              </div>
              <div className="bg-white dark:bg-slate-800/50 p-5 rounded-2xl border border-slate-200 dark:border-slate-700 break-inside-avoid">
                <h4 className="font-bold text-slate-900 dark:text-white mb-2">2.4. Документальное подтверждение</h4>
                <p className="text-sm">Скачивание ассета сопровождается формированием лицензионного документа. Лицензия существует отдельно от файла изображения. При споре ключевым доказательством выступает именно лицензия, а не сам файл.</p>
              </div>
            </div>
          </Section>

          <Section id="licenses" title="3. Типы лицензий Freepik и их логика">
            <p>Платформа Freepik использует модель лицензирования, разделяющую доступ к материалам по условиям использования и способу оплаты.</p>
            
            <h3 className="text-xl font-bold mt-8 mb-4 text-slate-900 dark:text-white">3.1. Бесплатная лицензия</h3>
            <ul className="list-disc pl-5 space-y-2 mb-6">
              <li>допускается коммерческое использование;</li>
              <li>в большинстве случаев <strong>требуется указание авторства</strong>;</li>
              <li>запрещается распространение ассета как самостоятельного продукта;</li>
              <li>ограничены способы передачи третьим лицам.</li>
            </ul>

            <h3 className="text-xl font-bold mb-4 text-slate-900 dark:text-white">3.2. Платная (Premium) лицензия</h3>
            <ul className="list-disc pl-5 space-y-2 mb-4">
              <li>атрибуция не требуется;</li>
              <li>допускается коммерческое применение;</li>
              <li>увеличивается перечень допустимых проектов.</li>
            </ul>
            <p className="mb-6">Важно учитывать, что лицензия привязана к аккаунту пользователя, а не к заказчику проекта.</p>

            <h3 className="text-xl font-bold mb-4 text-slate-900 dark:text-white">3.3. Запрет совместного использования (shared subscription)</h3>
            <p className="mb-4">Подписка предназначена для индивидуального использования владельцем аккаунта либо сотрудниками одной организации. Недопустимыми считаются: складчина, совместная покупка подписки несколькими фрилансерами, передача логина и пароля.</p>
            <p className="text-red-600 dark:text-red-400 font-medium mb-6">Такие действия могут привести к блокировке аккаунта и утрате лицензий на ранее скачанные материалы.</p>

            <h3 className="text-xl font-bold mb-4 text-slate-900 dark:text-white">3.4. Коммерческое использование и его пределы</h3>
            <p className="mb-4">Коммерческим считается любое использование, связанное с продвижением бизнеса, получением прибыли либо рекламой. Даже при наличии подписки могут существовать ограничения:</p>
            <ul className="list-disc pl-5 space-y-2">
              <li>использование в товарных знаках;</li>
              <li>создание логотипов;</li>
              <li>массовое тиражирование продукции.</li>
            </ul>
          </Section>

